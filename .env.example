# ============================================================
# .env.example — Copy this to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# --- LLM / AI ---
# GitHub Personal Access Token used to call Azure-hosted OpenAI models
GITHUB_TOKEN=your_github_token_here

# --- PostgreSQL Database ---
DB_USER=postgres
DB_PASS=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=SalesForecast

# Full connection string (optional — overrides the individual values above)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/SalesForecast

# --- Security ---
# Your admin API key to access the FastAPI endpoints
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your_strong_random_api_key_here

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
